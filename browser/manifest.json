{
  "manifest_version": 3,
  "name": "Lobstr NIP-07",
  "version": "1.0.0",
  "description": "Nostr identity management and signing (NIP-07)",
  "permissions": ["storage", "windows"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lobstr NIP-07"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lobstr-nip07@lobstr",
      "strict_min_version": "115.0"
    }
  }
}
